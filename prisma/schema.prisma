    followingId BigInt    @map("following_id") @db.UnsignedBigInt
    createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    follower    User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "follows_follower_id_foreign")
    following   User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "follows_following_id_foreign")

    @@index([followerId], map: "follows_follower_id_foreign")
    @@index([followingId], map: "follows_following_id_foreign")
    @@map("follows")
}

model Message {
    id                BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
    senderId          BigInt     @map("sender_id") @db.UnsignedBigInt
    receiverId        BigInt?    @map("receiver_id") @db.UnsignedBigInt
    msgBody           String?    @map("msg_body") @db.Text
    msgImage          String?    @map("msg_image") @db.VarChar(255)
    readAt            DateTime?  @map("read_at") @db.Timestamp(0)
    createdAt         DateTime?  @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt         DateTime?  @updatedAt @map("updated_at") @db.Timestamp(0)
    chatGroupId       BigInt?    @map("chat_group_id") @db.UnsignedBigInt
    senderDeletedAt   DateTime?  @map("sender_deleted_at") @db.Timestamp(0)
    receiverDeletedAt DateTime?  @map("receiver_deleted_at") @db.Timestamp(0)
    chatGroup         ChatGroup? @relation(fields: [chatGroupId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "messages_chat_group_id_foreign")
    receiver          User?      @relation("Receiver", fields: [receiverId], references: [id], onUpdate: NoAction, map: "messages_receiver_id_foreign")
    sender            User       @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "messages_sender_id_foreign")

    @@index([chatGroupId], map: "messages_chat_group_id_foreign")
    @@index([receiverId], map: "messages_receiver_id_foreign")
    @@index([senderId], map: "messages_sender_id_foreign")
    @@map("messages")
}

