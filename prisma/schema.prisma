generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model User {
    id                              BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
    patronId                        BigInt?                     @map("patron_id") @db.UnsignedBigInt
    name                            String                      @db.VarChar(255)
    username                        String?                     @db.VarChar(255)
    email                           String?                     @db.VarChar(255)
    phone                           String?                     @db.VarChar(255)
    pictureUrl                      String?                     @map("picture_url") @db.VarChar(255)
    cloudinaryPublicId              String?                     @map("cloudinary_public_id") @db.VarChar(255)
    regionId                        BigInt?                     @map("region_id") @db.UnsignedBigInt
    role                            Int                         @default(3)
    accountState                    Int                         @default(1) @map("account_state")
    country                         String?                     @db.VarChar(255)
    referralId                      BigInt?                     @map("referral_id") @db.UnsignedBigInt
    emailVerificationCode           String?                     @map("email_verification_code") @db.VarChar(255)
    emailVerificationCodeSentAt     DateTime?                   @map("email_verification_code_sent_at") @db.Timestamp(0)
    emailVerifiedAt                 DateTime?                   @map("email_verified_at") @db.Timestamp(0)
    password                        String                      @db.VarChar(255)
    passwordResetOtp                String?                     @map("password_reset_otp") @db.VarChar(255)
    passwordResetOtpSentAt          DateTime?                   @map("password_reset_otp_sent_at") @db.Timestamp(0)
    rememberToken                   String?                     @map("remember_token") @db.VarChar(100)
    createdAt                       DateTime?                   @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt                       DateTime?                   @updatedAt @map("updated_at") @db.Timestamp(0)
    status                          Boolean                     @default(false)
    withdrawalPin                   String?                     @map("withdrawal_pin") @db.VarChar(255)
    withdrawalPinResetOtp           String?                     @map("withdrawal_pin_reset_otp") @db.VarChar(255)
    withdrawalPinResetOtpSentAt     DateTime?                   @map("withdrawal_pin_reset_otp_sent_at") @db.Timestamp(0)
    referralActivateAt              DateTime?                   @map("referral_activate_at") @db.Timestamp(0)
    bank                            String?                     @db.VarChar(255)
    accountNumber                   String?                     @map("account_number") @db.VarChar(11)
    isInfant                        Boolean                     @default(false) @map("is_infant")
    birthDate                       DateTime?                   @map("birth_date") @db.Date
    birthPlace                      String?                     @map("birth_place") @db.VarChar(255)
    birthCertificate                String?                     @map("birth_certificate") @db.VarChar(255)
    infantGroupId                   BigInt?                     @map("infant_group_id") @db.UnsignedBigInt
    canWithdraw                     Boolean                     @default(true) @map("can_withdraw")
    canUseVtu                       Boolean                     @default(true) @map("can_use_vtu")
    deletedAt                       DateTime?                   @map("deleted_at") @db.Timestamp(0)
    canEarn                         Boolean                     @default(true) @map("can_earn")
    canOptOut                       Boolean                     @default(true) @map("can_opt_out")
    canWithdrawGkwth                Boolean                     @default(true) @map("can_withdraw_gkwth")
    lastSeen                        DateTime?                   @map("last_seen") @db.Timestamp(0)
    activatedAt                     DateTime?                   @map("activated_at") @db.Timestamp(0)
    has_verified_level_2            Boolean                     @default(false) @map("has_verified_level_2")
    upgradeToAdultAt                DateTime?                   @map("upgrade_to_adult_at") @db.Timestamp(0)
    isOnline                        Boolean                     @default(false) @map("is_online")
    sponsorshipAcceptedAt           DateTime?                   @map("sponsorship_accepted_at") @db.Timestamp(0)
    sponsorAgreement                Boolean?                    @map("sponsor_agreement")
    sponsorshipStatus               SponsorshipStatus?          @map("sponsorship_status")
    sponsorLoginOtp                 Int?                        @map("sponsor_login_otp")
    sponsorLoginOtpCreatedAt        DateTime?                   @map("sponsor_login_otp_created_at") @db.Timestamp(0)
    isSponsorAccount                String?                     @map("is_sponsor_account") @db.VarChar(255)
    influencerId                    BigInt?                     @map("influencer_id") @db.UnsignedBigInt
    accountActivationAcknowledgedAt DateTime?                   @map("account_activation_acknowledged_at") @db.Timestamp(0)
    sponsorWithdrawalOtp            Int?                        @map("sponsor_withdrawal_otp")
    sponsorWithdrawalOtpSentAt      DateTime?                   @map("sponsor_withdrawal_otp_sent_at") @db.Timestamp(0)
    isDeactivated                   Boolean                     @default(false) @map("is_deactivated")
    sponsorId                       BigInt?                     @map("sponsor_id") @db.UnsignedBigInt
    sponsorSlot                     Int                         @default(0) @map("sponsor_slot")
    loginYearlyCount                Json?                       @map("login_yearly_count")
    schoolFeesPermittedAt           DateTime?                   @map("school_fees_permitted_at") @db.Timestamp(0)
    withdrawalBypassAt              DateTime?                   @map("withdrawal_bypass_at") @db.Timestamp(0)
    isUnitLeader                    Boolean                     @default(false) @map("is_unit_leader")
    schoolId                        BigInt?                     @map("school_id") @db.UnsignedBigInt
    address                         String?                     @db.Text
    sponsorClass                    SponsorClass?               @map("sponsor_class")
    transferId                      String?                     @unique(map: "users_transfer_id_unique") @map("transfer_id") @db.VarChar(255)
    unblockingCode                  String?                     @map("unblocking_code") @db.VarChar(255)
    blockedAt                       DateTime?                   @map("blocked_at") @db.Timestamp(0)
    influencerPromoPeriodId         BigInt?                     @map("influencer_promo_period_id") @db.UnsignedBigInt
    guardianId                      BigInt?                     @map("guardian_id") @db.UnsignedBigInt
    guardianWardSlotId              BigInt?                     @map("guardian_ward_slot_id") @db.UnsignedBigInt
    pimId                           String?                     @unique(map: "users_pim_id_unique") @map("pim_id") @db.VarChar(255)
    patronGroupId                   BigInt?                     @map("patron_group_id") @db.UnsignedBigInt
    activationCardId                BigInt?                     @map("activation_card_id") @db.UnsignedBigInt
    refreshToken                    String?                     @map("refresh_token") @db.VarChar(255)
    level                           Int                         @default(1)
    activationCardTransactions      ActivationCardTransaction[]
    activationCardsApproved         ActivationCard[]            @relation("ACApprover")
    activationCardsOwned            ActivationCard[]            @relation("ACOwner")
    activationTeamMates             ActivationTeamMateUser[]    @ignore
    adminLogs                       AdminLog[]
    attemptLogins                   AttemptLogin[]
    blogs                           Blog[]
    carts                           Cart[]
    centralTreasuryLogs             CentralTreasuryLog[]
    chatGroupUsers                  ChatGroupUser[]             @ignore
    chatGroupsCreated               ChatGroup[]                 @relation("CGCreator")
    comments                        Comment[]
    followsAsFollower               Follow[]                    @relation("Follower")
    followsAsFollowing              Follow[]                    @relation("Following")
    guardianWardSlotPurchases       GuardianWardSlotPurchase[]  @relation("GWSUser")
    notifications                   NotificationUser[]
    infantFormFees                  InfantFormFee[]
    infantSchoolFeeGroups           InfantSchoolFeeGroup[]
    infantSchoolFees                InfantSchoolFee[]
    infantUpkeepRequests            InfantUpkeepRequest[]
    infantYearlyTopups              InfantYearlyTopup[]
    influencerYearlyTopupsApproved  InfluencerYearlyTopup[]     @relation("IYTApprover")
    influencerYearlyTopups          InfluencerYearlyTopup[]     @relation("IYTUser")
    likes                           Like[]
    loansAsResolver                 Loan[]                      @relation("LoanResolver")
    loansAsUser                     Loan[]                      @relation("LoanUser")
    receivedMessages                Message[]                   @relation("Receiver")
    sentMessages                    Message[]                   @relation("Sender")
    orderGroups                     OrderGroup[]
    patronGroupTransactions         PatronGroupTransaction[]
    patronGroupsOwned               PatronGroup[]               @relation("PGOwner")
    prizeUsers                      PrizeUser[]                 @ignore
    quizPhaseUsers                  QuizPhaseUser[]
    quizUsers                       QuizUser[]
    retweets                        Retweet[]
    schoolCompensationAsInfant      SchoolCompensation[]        @relation("SCInfant")
    schoolCompensationAsSchool      SchoolCompensation[]        @relation("SCSchool")
    schoolFees                      SchoolFee[]
    sponsorInvestmentReturnsSponsor SponsorInvestmentReturn[]   @relation("SIRSponsor")
    sponsorInvestmentReturns        SponsorInvestmentReturn[]   @relation("SIRUser")
    tweets                          Tweet[]
    unblockingPayments              UnblockingPayment[]
    userActivationRequests          UserActivationRequest[]
    activationCard                  ActivationCard?             @relation("ACToUser", fields: [activationCardId], references: [id], onUpdate: NoAction, map: "users_activation_card_id_foreign")
    guardianUser                    User?                       @relation("GuardianToUser", fields: [guardianId], references: [id], onUpdate: NoAction, map: "users_guardian_id_foreign")
    guardianWards                   User[]                      @relation("GuardianToUser")
    guardianWardSlot                GuardianWardSlotPurchase?   @relation("GWSToUser", fields: [guardianWardSlotId], references: [id], onUpdate: NoAction, map: "users_guardian_ward_slot_id_foreign")
    infantGroup                     User?                       @relation("InfantGroupToUser", fields: [infantGroupId], references: [id], onUpdate: NoAction, map: "users_infant_group_id_foreign")
    infantGroupMembers              User[]                      @relation("InfantGroupToUser")
    influencerUser                  User?                       @relation("InfluencerToUser", fields: [influencerId], references: [id], onUpdate: NoAction, map: "users_influencer_id_foreign")
    influencees                     User[]                      @relation("InfluencerToUser")
    influencer_promo_periods        InfluencerPromoPeriod?      @relation(fields: [influencerPromoPeriodId], references: [id], onUpdate: NoAction, map: "users_influencer_promo_period_id_foreign")
    patronGroup                     PatronGroup?                @relation(fields: [patronGroupId], references: [id], onUpdate: NoAction, map: "users_patron_group_id_foreign")
    patron                          User?                       @relation("PatronToUser", fields: [patronId], references: [id], onUpdate: NoAction, map: "users_patron_id_foreign")
    patronees                       User[]                      @relation("PatronToUser")
    referral                        User?                       @relation("ReferralToUser", fields: [referralId], references: [id], onUpdate: NoAction, map: "users_referral_id_foreign")
    referrals                       User[]                      @relation("ReferralToUser")
    region                          Region?                     @relation(fields: [regionId], references: [id], onUpdate: NoAction, map: "users_region_id_foreign")
    schoolUser                      User?                       @relation("SchoolToUser", fields: [schoolId], references: [id], onUpdate: NoAction, map: "users_school_id_foreign")
    schoolStudents                  User[]                      @relation("SchoolToUser")
    sponsorUser                     User?                       @relation("SponsorToUser", fields: [sponsorId], references: [id], onUpdate: NoAction, map: "users_sponsor_id_foreign")
    sponsorees                      User[]                      @relation("SponsorToUser")
    wallets                         Wallet[]
    wishlists                       Wishlist[]
    withDrawals                     WithDrawal[]

    @@index([role], map: "users_role_index")
    @@index([role, patronId], map: "users_role_patron_id_index")
    @@index([activationCardId], map: "users_activation_card_id_foreign")
    @@index([guardianId], map: "users_guardian_id_foreign")
    @@index([guardianWardSlotId], map: "users_guardian_ward_slot_id_foreign")
    @@index([infantGroupId], map: "users_infant_group_id_foreign")
    @@index([influencerId], map: "users_influencer_id_foreign")
    @@index([influencerPromoPeriodId], map: "users_influencer_promo_period_id_foreign")
    @@index([patronGroupId], map: "users_patron_group_id_foreign")
    @@index([patronId], map: "users_patron_id_foreign")
    @@index([referralId], map: "users_referral_id_foreign")
    @@index([regionId], map: "users_region_id_foreign")
    @@index([schoolId], map: "users_school_id_foreign")
    @@index([sponsorId], map: "users_sponsor_id_foreign")
    @@map("users")
}

model Region {
    id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    name      String    @db.VarChar(255)
    createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    max       Int       @default(3000000)
    prizes    Prize[]
    users     User[]

    @@map("regions")
}

model State {
    id          BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
    name        String       @db.VarChar(255)
    createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt   DateTime?    @updatedAt @map("updated_at") @db.Timestamp(0)
    lgas        LGA[]
    orderGroups OrderGroup[]

    @@map("states")
}

model LGA {
    id          BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
    name        String       @db.VarChar(255)
    stateId     BigInt       @map("state_id") @db.UnsignedBigInt
    createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt   DateTime?    @updatedAt @map("updated_at") @db.Timestamp(0)
    state       State        @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "l_g_a_s_state_id_foreign")
    orderGroups OrderGroup[]

    @@index([stateId], map: "l_g_a_s_state_id_foreign")
    @@map("l_g_a_s")
}

model Wallet {
    id                      BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
    type                    WalletType?
    amount                  Float                    @default(0.00)
    userId                  BigInt                   @map("user_id") @db.UnsignedBigInt
    createdAt               DateTime?                @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt               DateTime?                @updatedAt @map("updated_at") @db.Timestamp(0)
    centralTreasuryLogs     CentralTreasuryLog[]
    loans                   Loan[]
    manuallyFundings        ManuallyFunding[]
    orderTransactions       OrderTransaction[]
    patronGroupTransactions PatronGroupTransaction[]
    walletTransfersReceived WalletTransfer[]         @relation("ReceiverWallet")
    walletTransfersSent     WalletTransfer[]         @relation("SenderWallet")
    user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "wallets_user_id_foreign")
    withdrawalRequests      WithdrawalRequest[]

    @@index([userId], map: "wallets_user_id_foreign")
    @@map("wallets")
}

model AdminLog {
    id        BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
    adminId   BigInt      @map("admin_id") @db.UnsignedBigInt
    action    AdminAction
    modelId   Int         @map("model_id")
    modelType String      @map("model_type") @db.VarChar(255)
    oldValues Json        @map("old_values")
    newValues Json        @map("new_values")
    createdAt DateTime?   @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt DateTime?   @updatedAt @map("updated_at") @db.Timestamp(0)
    admin     User        @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "admin_logs_admin_id_foreign")

    @@index([adminId], map: "admin_logs_admin_id_foreign")
    @@map("admin_logs")
}

model CentralTreasuryLog {
    id              BigInt                          @id @default(autoincrement()) @db.UnsignedBigInt
    transactionType CentralTreasuryTransactionType? @map("transaction_type")
    walletId        BigInt                          @map("wallet_id") @db.UnsignedBigInt
    performedBy     BigInt                          @map("performed_by") @db.UnsignedBigInt
    amount          Float
    createdAt       DateTime?                       @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt       DateTime?                       @updatedAt @map("updated_at") @db.Timestamp(0)
    performer       User                            @relation(fields: [performedBy], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "central_treasury_logs_performed_by_foreign")
    wallet          Wallet                          @relation(fields: [walletId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "central_treasury_logs_wallet_id_foreign")

    @@index([performedBy], map: "central_treasury_logs_performed_by_foreign")
    @@index([walletId], map: "central_treasury_logs_wallet_id_foreign")
    @@map("central_treasury_logs")
}

model WalletTransfer {
    id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    senderWalletId   BigInt    @map("sender_wallet_id") @db.UnsignedBigInt
    receiverWalletId BigInt    @map("receiver_wallet_id") @db.UnsignedBigInt
    amount           BigInt    @db.UnsignedBigInt
    reference        String?   @unique(map: "wallet_transfers_reference_unique") @db.VarChar(255)
    createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt        DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    receiverWallet   Wallet    @relation("ReceiverWallet", fields: [receiverWalletId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "wallet_transfers_receiver_wallet_id_foreign")
    senderWallet     Wallet    @relation("SenderWallet", fields: [senderWalletId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "wallet_transfers_sender_wallet_id_foreign")

    @@index([receiverWalletId], map: "wallet_transfers_receiver_wallet_id_foreign")
    @@index([senderWalletId], map: "wallet_transfers_sender_wallet_id_foreign")
    @@map("wallet_transfers")
}

model ManuallyFunding {
    id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    walletId          BigInt    @map("wallet_id") @db.UnsignedBigInt
    amount            String    @db.VarChar(255)
    gkwthValuePerUnit String?   @map("gkwth_value_per_unit") @db.VarChar(255)
    gkwthAmountToSend String?   @map("gkwth_amount_to_send") @db.VarChar(255)
    receipt           String    @db.VarChar(255)
    createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt         DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    wallet            Wallet    @relation(fields: [walletId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "manually_fundings_wallet_id_foreign")

    @@index([walletId], map: "manually_fundings_wallet_id_foreign")
    @@map("manually_fundings")
}

model Ad {
    id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    frameLink    String    @map("frame_link") @db.VarChar(255)
    externalLink String    @map("external_link") @db.VarChar(255)
    startDate    DateTime  @map("start_date") @db.Date
    endDate      DateTime  @map("end_date") @db.Date
    createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)

    @@map("ads")
}

model Advert {
    id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    imageUrl           String    @map("image_url") @db.Text
    cloudinaryPublicId String    @map("cloudinary_public_id") @db.Text
    link               String    @db.Text
    createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt          DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)

    @@map("adverts")
}

model AttemptLogin {
    id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    userId     BigInt    @map("user_id") @db.UnsignedBigInt
    noOfTrials Int       @map("no_of_trials")
    createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "attempt_logins_user_id_foreign")

    @@index([userId], map: "attempt_logins_user_id_foreign")
    @@map("attempt_logins")
}

model Blog {
    id                 BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
    title              String        @unique(map: "blogs_title_unique") @db.VarChar(255)
    body               String        @db.LongText
    imageUrl           String        @map("image_url") @db.VarChar(255)
    cloudinaryPublicId String        @map("cloudinary_public_id") @db.VarChar(255)
    userId             BigInt?       @map("user_id") @db.UnsignedBigInt
    createdAt          DateTime?     @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt          DateTime?     @updatedAt @map("updated_at") @db.Timestamp(0)
    comments           BlogComment[]
    user               User?         @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "blogs_user_id_foreign")

    @@index([userId], map: "blogs_user_id_foreign")
    @@map("blogs")
}

model BlogComment {
    id        BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
    blogId    BigInt        @map("blog_id") @db.UnsignedBigInt
    commentId BigInt?       @map("comment_id") @db.UnsignedBigInt
    name      String        @db.VarChar(255)
    comment   String        @db.Text
    createdAt DateTime?     @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt DateTime?     @updatedAt @map("updated_at") @db.Timestamp(0)
    blog      Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_comments_blog_id_foreign")
    parent    BlogComment?  @relation("BlogCommentReply", fields: [commentId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_comments_comment_id_foreign")
    replies   BlogComment[] @relation("BlogCommentReply")

    @@index([blogId], map: "blog_comments_blog_id_foreign")
    @@index([commentId], map: "blog_comments_comment_id_foreign")
    @@map("blog_comments")
}

model Tweet {
    id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    userId             BigInt    @map("user_id") @db.UnsignedBigInt
    status             String?   @db.VarChar(255)
    img                String?   @db.VarChar(255)
    cloudinaryPublicId String    @map("cloudinary_public_id") @db.VarChar(255)
    createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt          DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    user               User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tweets_user_id_foreign")

    @@index([userId], map: "tweets_user_id_foreign")
    @@map("tweets")
}

model Retweet {
    id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    retweetMsg         String?   @map("retweet_msg") @db.VarChar(255)
    retweetImg         String?   @map("retweet_img") @db.VarChar(255)
    cloudinaryPublicId String    @map("cloudinary_public_id") @db.VarChar(255)
    userId             BigInt?   @map("user_id") @db.UnsignedBigInt
    retweetableType    String    @map("retweetable_type") @db.VarChar(255)
    retweetableId      BigInt    @map("retweetable_id") @db.UnsignedBigInt
    createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt          DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    user               User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "retweets_user_id_foreign")

    @@index([retweetableType, retweetableId], map: "retweets_retweetable_type_retweetable_id_index")
    @@index([userId], map: "retweets_user_id_foreign")
    @@map("retweets")
}

model Comment {
    id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    comment         String    @db.VarChar(255)
    userId          BigInt    @map("user_id") @db.UnsignedBigInt
    commentableType String    @map("commentable_type") @db.VarChar(255)
    commentableId   BigInt    @map("commentable_id") @db.UnsignedBigInt
    createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt       DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comments_user_id_foreign")

    @@index([commentableType, commentableId], map: "comments_commentable_type_commentable_id_index")
    @@index([userId], map: "comments_user_id_foreign")
    @@map("comments")
}

model Like {
    id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    userId       BigInt    @map("user_id") @db.UnsignedBigInt
    likeableType String    @map("likeable_type") @db.VarChar(255)
    likeableId   BigInt    @map("likeable_id") @db.UnsignedBigInt
    createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "likes_user_id_foreign")

    @@index([likeableType, likeableId], map: "likes_likeable_type_likeable_id_index")
    @@index([userId], map: "likes_user_id_foreign")
    @@map("likes")
}

model Follow {
    id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
