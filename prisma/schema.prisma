model Loan {
    id                 BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
    userId             BigInt     @map("user_id") @db.UnsignedBigInt
    walletId           BigInt?    @map("wallet_id") @db.UnsignedBigInt
    status             LoanStatus @default(pending)
    cancellationReason String?    @map("cancellation_reason") @db.VarChar(255)
    quantityRequested  Float      @map("quantity_requested")
    quantityGranted    Float      @default(0.00) @map("quantity_granted")
    acceptedAt         DateTime?  @map("accepted_at") @db.Timestamp(0)
    rejectedAt         DateTime?  @map("rejected_at") @db.Timestamp(0)
    resolvedBy         BigInt?    @map("resolved_by") @db.UnsignedBigInt
    resolvedAt         DateTime?  @map("resolved_at") @db.Timestamp(0)
    quantityRepaid     Float      @default(0.00) @map("quantity_repaid")
    createdAt          DateTime?  @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt          DateTime?  @updatedAt @map("updated_at") @db.Timestamp(0)
    gkwthPrice         Float?     @map("gkwth_price")
    isPaid             Boolean    @default(false)
    receipt            String?    @db.VarChar(255)
    resolver           User?      @relation("LoanResolver", fields: [resolvedBy], references: [id], onUpdate: NoAction, map: "loans_resolved_by_foreign")
    user               User       @relation("LoanUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "loans_user_id_foreign")
    wallet             Wallet?    @relation(fields: [walletId], references: [id], onUpdate: NoAction, map: "loans_wallet_id_foreign")

    @@index([resolvedBy], map: "loans_resolved_by_foreign")
    @@index([userId], map: "loans_user_id_foreign")
    @@index([walletId], map: "loans_wallet_id_foreign")
    @@map("loans")
}

