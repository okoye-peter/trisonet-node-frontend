    createdAt               DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt               DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)
    quizPhase               QuizPhase @relation(fields: [quizPhaseId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "quiz_phase_user_quiz_phase_id_foreign")
    user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "quiz_phase_user_user_id_foreign")

    @@index([quizPhaseId], map: "quiz_phase_user_quiz_phase_id_foreign")
    @@index([userId], map: "quiz_phase_user_user_id_foreign")
    @@map("quiz_phase_user")
}

model Prize {
    id           BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
    name         String      @db.VarChar(255)
    url          String?     @db.VarChar(255)
    type         PrizeType   @default(awards)
    regionId     BigInt?     @map("region_id") @db.UnsignedBigInt
    position     Int
    totalPersons Json        @map("total_persons")
    location     String?     @db.LongText
    createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt    DateTime?   @updatedAt @map("updated_at") @db.Timestamp(0)
    users        PrizeUser[] @ignore
    region       Region?     @relation(fields: [regionId], references: [id], onUpdate: NoAction, map: "prizes_region_id_foreign")

    @@index([regionId], map: "prizes_region_id_foreign")
    @@map("prizes")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model PrizeUser {
    userId  BigInt @map("user_id") @db.UnsignedBigInt
    prizeId BigInt @map("prize_id") @db.UnsignedBigInt
    prize   Prize  @relation(fields: [prizeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "prize_user_prize_id_foreign")
    user    User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "prize_user_user_id_foreign")

    @@index([prizeId], map: "prize_user_prize_id_foreign")
    @@index([userId], map: "prize_user_user_id_foreign")
    @@map("prize_user")
    @@ignore
}

model Reel {
    id                 BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
    url                String       @db.VarChar(255)
    cloudinaryPublicId String       @map("cloudinary_public_id") @db.VarChar(255)
    fileType           ReelFileType @map("file_type")
    createdAt          DateTime?    @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt          DateTime?    @updatedAt @map("updated_at") @db.Timestamp(0)

    @@map("reels")
}

model LaravelMigration {
    id        Int    @id @default(autoincrement()) @db.UnsignedInt
    migration String @db.VarChar(255)
    batch     Int

    @@map("migrations")
}

model Audit {
    id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
    userType      String?   @map("user_type") @db.VarChar(255)
    userId        BigInt?   @map("user_id") @db.UnsignedBigInt
    event         String    @db.VarChar(255)
    auditableType String    @map("auditable_type") @db.VarChar(255)
    auditableId   BigInt    @map("auditable_id") @db.UnsignedBigInt
    oldValues     String?   @map("old_values") @db.Text
    newValues     String?   @map("new_values") @db.Text
    url           String?   @db.Text
    ipAddress     String?   @map("ip_address") @db.VarChar(45)
    userAgent     String?   @map("user_agent") @db.VarChar(1023)
    tags          String?   @db.VarChar(255)
    createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamp(0)

    @@index([auditableType, auditableId], map: "audits_auditable_type_auditable_id_index")
    @@index([userId, userType], map: "audits_user_id_user_type_index")
    @@map("audits")
}

model AuthHandoffToken {
    id        BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
    userId    BigInt   @map("user_id") @db.UnsignedBigInt
    token     String   @db.VarChar(255)
    used      Boolean  @default(false)
    expiresAt DateTime @map("expires_at") @db.Timestamp(0)
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

    @@map("auth_handoff_tokens")
}

model failed_jobs {
    id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
    uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
    connection String   @db.Text
    queue      String   @db.Text
    payload    String   @db.LongText
    exception  String   @db.LongText
    failed_at  DateTime @default(now()) @db.Timestamp(0)
}

model EarningSettings {
    id        Int      @id @default(autoincrement()) @db.UnsignedInt
    name      String   @db.VarChar(255)
    value     String   @db.VarChar(255)
    description String   @db.Text
    isActive Boolean  @default(true) @map("ia_active")
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

    @@map("earning_settings")
}

model EarningTransaction {
    id        Int      @id @default(autoincrement()) @db.UnsignedInt
    amount    Float    @db.Float
    type      String   @db.VarChar(255)
    reference String   @db.VarChar(255) @unique(map: "earning_transactions_reference_unique")
    walletId Int      @map("wallet_id") @db.UnsignedInt
    narration String   @db.Text
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

    @@map("earning_transactions")
}

